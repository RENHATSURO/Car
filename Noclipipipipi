-- ================= STATES =================
local moneyEnabled = false
local trafficEnabled = false

-- ================= MONEY SYSTEM =================
local function giveMoney()
    local remoteMoney = game:GetService("ReplicatedStorage"):FindFirstChild("GiveMoneyEvent")
    local remoteXP = game:GetService("ReplicatedStorage"):FindFirstChild("AddXPEvent")

    if not remoteMoney or not remoteXP then
        warn("RemoteEvents introuvables")
        return
    end

    while moneyEnabled do
        remoteMoney:FireServer(2500, "Driving income")
        remoteXP:FireServer(2500)

        task.wait(0.2) -- plus safe
    end
end

moneyButton.MouseButton1Click:Connect(function()
    moneyEnabled = not moneyEnabled

    if moneyEnabled then
        moneyButton.Text = "Money ON"
        moneyButton.BackgroundColor3 = Color3.fromRGB(0, 170, 0)
        task.spawn(giveMoney)
    else
        moneyButton.Text = "Money OFF"
        moneyButton.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
    end
end)

-- ================= TRAFFIC CLEANER =================
local function processTraffic()
    local trafficFolder = workspace:FindFirstChild("Traffic")
    if not trafficFolder then return end

    for _, model in ipairs(trafficFolder:GetChildren()) do
        if model:IsA("Model") then
            local part = model:FindFirstChild("Part")
            if part then
                local aiBody = part:FindFirstChild("AI_CarBody")

                if aiBody then
                    local hitbox = aiBody:FindFirstChild("HITBOX")
                    if hitbox then hitbox:Destroy() end

                    for _, child in ipairs(aiBody:GetChildren()) do
                        if child.Name:match("%$wheel") then
                            child:Destroy()
                        end
                    end

                    local vehicleLights = aiBody:FindFirstChild("Vehicle_Lights")
                    if vehicleLights then vehicleLights:Destroy() end
                end

                local directHitbox = part:FindFirstChild("HITBOX")
                if directHitbox then directHitbox:Destroy() end

                local lights = part:FindFirstChild("Lights")
                if lights then lights:Destroy() end
            end
        end
    end
end

task.spawn(function()
    while true do
        if trafficEnabled then
            processTraffic()
        end
        task.wait(0.5)
    end
end)

trafficButton.MouseButton1Click:Connect(function()
    trafficEnabled = not trafficEnabled

    if trafficEnabled then
        trafficButton.Text = "Traffic ON"
        trafficButton.BackgroundColor3 = Color3.fromRGB(50, 200, 50)
    else
        trafficButton.Text = "Traffic OFF"
        trafficButton.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
    end
end)
