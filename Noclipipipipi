-- ================= MONEY SYSTEM =================
local function giveMoney()
    local remoteMoney = game:GetService("ReplicatedStorage"):WaitForChild("GiveMoneyEvent")
    local remoteXP = game:GetService("ReplicatedStorage"):WaitForChild("AddXPEvent")

    while moneyEnabled do
        -- 💰 Argent (inchangé)
        remoteMoney:FireServer(2500, "Driving income")
        
        -- ⭐ XP (remplace Near miss)
        remoteXP:FireServer(2500)

        task.wait(0.03)
    end
end
moneyButton.MouseButton1Click:Connect(function()
    moneyEnabled = not moneyEnabled

    if moneyEnabled then
        moneyButton.Text = "Money ON"
        moneyButton.BackgroundColor3 = Color3.fromRGB(0, 170, 0)
        task.spawn(giveMoney)
    else
        moneyButton.Text = "Money OFF"
        moneyButton.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
    end
end)

-- ================= TRAFFIC CLEANER =================
local wheelsToDelete = {
    ["$wheel0"] = true,
    ["$wheel1"] = true,
    ["$wheel2"] = true,
    ["$wheel3"] = true
}

local function processTraffic()
    local trafficFolder = workspace:FindFirstChild("Traffic")
    if not trafficFolder then return end

    for _, model in ipairs(trafficFolder:GetChildren()) do
        if model:IsA("Model") then
            
            local part = model:FindFirstChild("Part")
            if part then
                
                local aiBody = part:FindFirstChild("AI_CarBody")
                if aiBody then
                    
                    -- HITBOX AI_CarBody
                    local hitbox = aiBody:FindFirstChild("HITBOX")
                    if hitbox and hitbox:IsA("BasePart") then
                        hitbox:Destroy()
                    end

                    -- Wheels
                    for _, child in ipairs(aiBody:GetChildren()) do
                        if wheelsToDelete[child.Name] then
                            child:Destroy()
                        end
                    end

                    -- Vehicle Lights
                    local vehicleLights = aiBody:FindFirstChild("Vehicle_Lights")
                    if vehicleLights then
                        vehicleLights:Destroy()
                    end
                end

                -- HITBOX direct
                local directHitbox = part:FindFirstChild("HITBOX")
                if directHitbox and directHitbox:IsA("BasePart") then
                    directHitbox:Destroy()
                end

                -- Lights
                local lights = part:FindFirstChild("Lights")
                if lights then
                    lights:Destroy()
                end
            end
        end
    end
end

-- Loop traffic
task.spawn(function()
    while true do
        if trafficEnabled then
            processTraffic()
        end
        task.wait(0.5)
    end
end)

